    }
  },

  "approval_workflow": {
    "designation_based_routing": {
      "Student Relationship Officer": {
        "approval_level_1": "State Business Head",
        "final_approval": "Mansoor"
      },
      "Business Operation Associate": {
        "approval_level_1": "State Business Head",
        "final_approval": "Mansoor"
      },
      "Area Business Head": {
        "approval_level_1": "State Business Head",
        "final_approval": "Mansoor"
      },
      "State Business Head": {
        "approval_level_1": null,
        "final_approval": "Mansoor"
      },
      "Zonal Business Head": {
        "approval_level_1": null,
        "final_approval": "Mansoor"
      },
      "Program Manager": {
        "approval_level_1": null,
        "final_approval": "Mansoor"
      }
    }
  },

  "employee_master_data": {
    "fields": [
      "employee_id",
      "employee_name",
      "employee_email",
      "state",
      "designation",
      "approval_mail_id_level_1",
      "approval_mail_id_level_2",
      "approval_mail_id_level_3"
    ],
    "purpose": "Defines designation, state, and approval hierarchy for each employee.",
    "reference_file": ".github/knowledge/employees.json"
  },

  "system_validations": [
    "Future dates must not be selectable.",
    "Maximum selectable date range is 7 days.",
    "Records must be stored as individual daily entries.",
    "Vehicle type options must be restricted based on designation.",
    "Taxi bills disable fuel reimbursement for that day.",
    "Only one fuel reimbursement allowed per day.",
    "KM travelled must respect maximum limits depending on vehicle type.",
    "Outstation location must be selected from dropdowns instead of plain text."
  ],

  "designations": [
    "Student Relationship Officer",
    "Business Operation Associate",
    "Area Business Head",
    "State Business Head",
    "Zonal Business Head",
    "Program Manager"
  ]
}
