{
  "name": "NxtExpense",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --max-http-header-size=32768 ./node_modules/next/dist/bin/next dev",
    "dev:provision-test-accounts": "node --env-file=.env.local scripts/dev/provision-test-accounts.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:staged": "lint-staged",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ui": "npx vitest --coverage --ui",
    "test:e2e": "playwright test --project=chromium --workers=1",
    "test:e2e:ci": "playwright test --project=chromium --workers=1",
    "test:e2e:parallel": "playwright test --project=chromium --workers=50%",
    "test:e2e:live:fast": "playwright test --project=chromium --headed --workers=50% --grep-invert \"Approval Workflow Matrix|Approval Workflow — SRO claim through full chain|Approval Rejection Flows|Finance Rejection Flows\"",
    "test:e2e:live:workflow": "playwright test e2e/approval-workflow-matrix.spec.ts e2e/approval-rejection-flows.spec.ts e2e/finance-rejection-flows.spec.ts --project=chromium --headed --workers=1",
    "test:e2e:live": "npm run test:e2e:live:fast && npm run test:e2e:live:workflow",
    "test:e2e:ui": "playwright test --ui --project=chromium",
    "test:e2e:rejections": "playwright test e2e/approval-rejection-flows.spec.ts e2e/finance-rejection-flows.spec.ts --project=chromium",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "dayjs": "^1.11.19",
    "lenis": "^1.3.18",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "msw": "^2.12.10",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
